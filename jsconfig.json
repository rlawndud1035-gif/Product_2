{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },
  "exclude": ["node_modules", "dist"],
  "include": ["src/**/*", "main.js", "*.config.js"]
}